{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": [],
    "paths": {
      "@y-core/forge/*": [
        "../forge/src/*/mod.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.ts",
    ".types/**/*.d.ts"
  ]
}
